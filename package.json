{
  "name": "sb-vue",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test:run"
  },
  "dependencies": {
    "dom-parser": "^0.1.6",
    "localforage": "^1.10.0",
    "steamid": "^2.0.0",
    "vue": "^3.2.26",
    "vue-router": "^4.0.13",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.0.18",
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}

